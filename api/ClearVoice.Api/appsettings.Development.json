{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },

  "Keycloak": {
    "Authority": "http://localhost:8080/realms/clearvoice",
    "Audience": "clearvoice-ui",
    "RequireHttpsMetadata": false
  },

  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=clearvoice;Username=clearvoice;Password=clearvoice_dev"
  },

  "Storage": {
    "Provider": "S3",
    "S3": {
      "BucketName": "clearvoice-recordings",
      "Region": "us-east-1",
      "UseIRSA": false,
      "ServiceUrl": "http://localhost:9100",
      "ForcePathStyle": true,
      "PresignedUrlHostOverride": "http://localhost:9100"
    }
  },

  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}
