# ─────────────────────────────────────────────────────────────────────────────
# ClearVoice local development environment variables
#
# These are read by:
#   • docker-compose (automatically)
#   • your shell when running `dotnet run` natively — source this file first:
#       source .env   (bash/zsh)
#
# DO NOT commit real secrets. This file is for local dev only.
# ─────────────────────────────────────────────────────────────────────────────

# MinIO credentials — must match MINIO_ROOT_USER/MINIO_ROOT_PASSWORD in docker-compose.yml
AWS_ACCESS_KEY_ID=clearvoice
AWS_SECRET_ACCESS_KEY=clearvoice_dev_secret
AWS_DEFAULT_REGION=us-east-1
